<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.happyim.common.mapper.AdminUserMapper">

    <resultMap id="adminUserMap" type="com.happyim.common.model.entity.AdminUser">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="createdTime" column="created_time"/>
    </resultMap>

    <select id="findByUsername" resultMap="adminUserMap">
        SELECT * FROM admin_user WHERE username = #{username}
    </select>

    <select id="findById" resultMap="adminUserMap">
        SELECT * FROM admin_user WHERE id = #{id}
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM admin_user
    </select>

    <insert id="insert">
        INSERT INTO admin_user (username, password, nickname)
        VALUES (#{username}, #{password}, #{nickname})
    </insert>

</mapper>
