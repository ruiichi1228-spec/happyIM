<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.happyim.common.mapper.UserMapper">

    <resultMap id="userMap" type="com.happyim.common.model.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="email" column="email"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="avatarUrl" column="avatar_url"/>
        <result property="gender" column="gender"/>
        <result property="signature" column="signature"/>
        <result property="description" column="description"/>
        <result property="emailVerified" column="email_verified"/>
        <result property="status" column="status"/>
        <result property="lastLoginTime" column="last_login_time"/>
        <result property="lastLoginIp" column="last_login_ip"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.happyim.common.model.entity.User">
        INSERT INTO user (id, username, email, password, nickname, avatar_url, email_verified, status)
        VALUES (#{id}, #{username}, #{email}, #{password}, #{nickname}, #{avatarUrl}, #{emailVerified}, #{status})
    </insert>

    <select id="findByEmail" resultMap="userMap">
        SELECT * FROM user WHERE email = #{email}
    </select>

    <select id="findByUsername" resultMap="userMap">
        SELECT * FROM user WHERE username = #{username}
    </select>

    <select id="findById" resultMap="userMap">
        SELECT * FROM user WHERE id = #{id}
    </select>

    <update id="updatePassword">
        UPDATE user SET password = #{password} WHERE id = #{id}
    </update>

    <update id="updateLoginInfo">
        UPDATE user SET last_login_time = NOW(), last_login_ip = #{ip} WHERE id = #{id}
    </update>

    <update id="updateProfile">
        UPDATE user
        SET nickname = #{nickname}, avatar_url = #{avatarUrl},
            gender = #{gender}, signature = #{signature}, description = #{description}
        WHERE id = #{id}
    </update>

    <select id="searchByKeyword" resultMap="userMap">
        SELECT * FROM user
        WHERE username LIKE CONCAT('%', #{keyword}, '%')
           OR nickname LIKE CONCAT('%', #{keyword}, '%')
           OR email LIKE CONCAT('%', #{keyword}, '%')
        LIMIT 20
    </select>

    <select id="findByIds" resultMap="userMap">
        SELECT * FROM user WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </select>

</mapper>
