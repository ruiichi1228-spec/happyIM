<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.happyim.common.mapper.FriendRequestMapper">

    <resultMap id="requestMap" type="com.happyim.common.model.entity.FriendRequest">
        <id property="id" column="id"/>
        <result property="fromUserId" column="from_user_id"/>
        <result property="toUserId" column="to_user_id"/>
        <result property="message" column="message"/>
        <result property="status" column="status"/>
        <result property="handledTime" column="handled_time"/>
        <result property="createdTime" column="created_time"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO friend_request (from_user_id, to_user_id, message, status)
        VALUES (#{fromUserId}, #{toUserId}, #{message}, #{status})
    </insert>

    <select id="findPending" resultMap="requestMap">
        SELECT * FROM friend_request
        WHERE from_user_id = #{fromUserId} AND to_user_id = #{toUserId} AND status = 0
    </select>

    <select id="findByToUserId" resultMap="requestMap">
        SELECT * FROM friend_request WHERE to_user_id = #{toUserId} ORDER BY created_time DESC
    </select>

    <select id="findById" resultMap="requestMap">
        SELECT * FROM friend_request WHERE id = #{id}
    </select>

    <update id="updateStatus">
        UPDATE friend_request SET status = #{status}, handled_time = NOW() WHERE id = #{id}
    </update>

</mapper>
